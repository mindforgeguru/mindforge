# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=mindforge
POSTGRES_USER=mindforge
POSTGRES_PASSWORD=change_me_db_password
DB_URL=postgresql+asyncpg://mindforge:change_me_db_password@postgres:5432/mindforge

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ─── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET_TESTS=mindforge-tests
MINIO_BUCKET_PROFILES=mindforge-profiles
MINIO_BUCKET_PDFS=mindforge-pdfs
MINIO_USE_SSL=false

# ─── JWT / Security ──────────────────────────────────────────────────────────
# REQUIRED. App refuses to start if unset. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 6-digit MPIN used to seed the default `admin` user on first boot only.
# Leave unset (or set to anything that isn't a 6-digit number) to skip the
# seed entirely. Must be set the first time you bring up a fresh database;
# can be left unset on subsequent boots.
ADMIN_SEED_MPIN=

# ─── Groq AI API ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ─── App Settings ────────────────────────────────────────────────────────────
APP_NAME=MIND FORGE
# APP_ENV controls dev-only surfaces. Default ("production") hides /docs,
# /redoc, /openapi.json. Set to "development" only on a dev machine.
APP_ENV=production
# Keep DEBUG=false in production. Only flip to true on a dev machine if you
# wire up a feature that reads settings.DEBUG (verbose errors, debug toolbar, etc).
DEBUG=false
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]

# ─── Nginx / Public URLs ─────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost
